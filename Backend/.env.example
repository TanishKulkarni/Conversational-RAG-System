# Environment Variables for University Policy Assistant Backend

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://university-policy-assistant.onrender.com

# Groq Configuration (Required for production)
GROQ_API_KEY="Your_Groq_API_key"
GROQ_MODEL=llama3-8b-8192
GROQ_TEMPERATURE=0.2

# Optional: Custom model settings
# GROQ_MODEL=llama3-70b-8192  # For better quality but higher cost
# GROQ_TEMPERATURE=0.1  # For more deterministic responses